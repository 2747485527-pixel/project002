MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=air_quality
MYSQL_CONNECT_TIMEOUT_MS=12000

# 模式 A：你自己的“全国一次返回所有城市”的 API 地址（可选）
API_URL=
API_AUTH_HEADER=
API_AUTH_VALUE=
API_INSECURE_TLS=false

# 模式 C：Open-Meteo（无需 key）
OPEN_METEO_ENABLED=true
OPEN_METEO_WEATHER_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_AIR_URL=https://air-quality-api.open-meteo.com/v1/air-quality
OPEN_METEO_CONCURRENCY=10
OPEN_METEO_INSECURE_TLS=false

# 模式 B：和风天气（QWeather）（可选）
QWEATHER_KEY=
QWEATHER_BASE_URL=https://devapi.qweather.com
QWEATHER_GEO_BASE_URL=https://geoapi.qweather.com
QWEATHER_WEATHER_NOW_PATH=/v7/weather/now
QWEATHER_AIR_NOW_PATH=/v7/air/now
QWEATHER_GEO_LOOKUP_PATH=/v2/city/lookup
QWEATHER_LANG=zh
QWEATHER_UNIT=m
QWEATHER_CONCURRENCY=10

# 城市种子列表（包含 adcode + lon/lat）
CITY_SEED_LIST_PATH=./data/prefecture_cities_seed.json
CITY_GEOJSON_PATH=

BATCH_SIZE=500

